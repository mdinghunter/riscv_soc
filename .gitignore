# ── Claude Code local config (personal, not project code) ────────────────────
.claude/

# ── Vivado generated output ───────────────────────────────────────────────────
# These are fully regenerated by Vivado; committing them bloats the repo with
# hundreds of MB of binary build artifacts.
riscv_soc.cache/
riscv_soc.gen/
riscv_soc.hw/
riscv_soc.ip_user_files/
riscv_soc.runs/

# Synthesis checkpoint — generated output, not source
riscv_soc.srcs/utils_1/

# ── Simulation working directory ──────────────────────────────────────────────
# Exclude Vivado-generated sim artifacts. Hand-written TCL and text.dat are
# tracked by not matching any rule here.
riscv_soc.sim/sim_1/behav/xsim/xsim.dir/
riscv_soc.sim/sim_1/behav/xsim/*.pb
riscv_soc.sim/sim_1/behav/xsim/*.wdb
riscv_soc.sim/sim_1/behav/xsim/xsim.ini
riscv_soc.sim/sim_1/behav/xsim/glbl.v
riscv_soc.sim/sim_1/behav/xsim/top.tcl
riscv_soc.sim/sim_1/behav/xsim/top_tb.tcl
riscv_soc.sim/sim_1/behav/xsim/top_tb_vlog.prj
riscv_soc.sim/sim_1/behav/xsim/dfx_runtime.txt
riscv_soc.sim/sim_1/behav/xsim/compile.bat
riscv_soc.sim/sim_1/behav/xsim/elaborate.bat
riscv_soc.sim/sim_1/behav/xsim/simulate.bat
riscv_soc.sim/sim_1/behav/xsim/top_behav.sh

# ── Test build artifacts ───────────────────────────────────────────────────────
# Compiled ELF/binary outputs — reproducible from source via make.
# Keep: text.dat (the hex image loaded by the simulator), source, Makefiles.
test/*/prog.elf
test/*/prog.bin
test/*/prog.dump

# Root-level text.dat is a symlink/copy used during simulation; not canonical.
/text.dat

# ── Vivado project journal / recovery files ───────────────────────────────────
*.jou
*.log
*.str
*.debug
webtalk*.xml
webtalk*.jou
.Xil/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
